{
  // Define la carpeta de salida para los archivos generados por LaTeX
  "latex-workshop.latex.outDir": "%DIR%/build",
  "latex-workshop.latex.tools": [
    {
      "name": "latexmk",             // Nombre de la herramienta de compilación
      "command": "latexmk",          // Comando para ejecutar la herramienta
      "args": [
        "-synctex=1",                // Habilita SyncTeX para sincronización entre el código fuente y el PDF
        "-interaction=nonstopmode",  // Continúa la compilación incluso si hay errores
        "-file-line-error",          // Muestra errores con formato de línea y archivo
        "-pdf",                      // Indica que la salida debe ser un PDF
        "-outdir=%OUTDIR%",          // Usa la carpeta de salida definida anteriormente (build)
        "-shell-escape",             // Permite la ejecución de comandos externos (necesario para paquetes como minted)
        "%DOC%"
      ],
      "env": {}
    }
  ],
  "latex-workshop.latex.recipes": [
    {
      // Define la compilación que utiliza la herramienta latexmk
      "name": "Compilación Maestra (latexmk)",
      "tools": [
        "latexmk"                    // Especifica que utiliza la herramienta latexmk
      ]
    }
  ],
  // Argumentos del linter ChkTeX (panel "Problems").
  // Conserva los valores por defecto (-n22 -n30 -e16) y silencia avisos
  // opinables o que aquí son falsos positivos sobre código literal:
  //  -n1  Command terminated with space (inocuo en defs. de macros/entornos)
  //  -n6  No italic correction (falso positivo)
  //  -n8  Wrong length of dash (identificadores/fechas: CPTIS-2302-2026, 2026-04-12)
  //  -n11 Use \ldots (placeholders dentro de \comando{...})
  //  -n12 Interword spacing (falso positivo)
  //  -n13 Intersentence spacing \@ (falso positivo en abreviaturas)
  //  -n18 Use `` '' en vez de " (comillas literales en JSON/shell mostrados)
  //  -n26 Spaces in front of punctuation (rutas/comandos: .env, docker build .)
  //  -n36 Space in front of parenthesis (código: auth.uid())
  //  -n44 User Regex (booktabs / reglas verticales: diseño de tablas con color, intencional)
  "latex-workshop.chktex.args": [
    "-wall", "-n22", "-n30", "-e16", "-q", "-f%f:%l:%c:%d:%k:%m\n",
    "-n1", "-n6", "-n8", "-n11", "-n12", "-n13", "-n18", "-n26", "-n36", "-n44"
  ],

  // Configura la compilación automática para que se ejecute al guardar el archivo con Ctrl+S
  "latex-workshop.latex.autoBuild.run": "onSave",
  // Mantiene limpios los subdirectorios de salida después de la compilación
  "latex-workshop.latex.clean.subfolder.enabled": true,
  // Abre el pdf generado en una nueva pestaña dentro de Visual Studio Code
  "latex-workshop.view.pdf.viewer": "tab"
}